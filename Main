from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import FileResponse 

from routers.gastos import router as gastos_router
from routers.categorias import router as categorias_router
from routers.dashboard import router as dashboard_router

app = FastAPI(
    title="MyPocketBudget API",
    description=(
        "Backend do MyPocketBudget.\n\n"
        "**Padrões de projeto:** Prototype · Bridge · Strategy\n\n"
        "**OO:** Classe abstrata · Polimorfismo · Herança"
    ),
    version="1.0.0",
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

app.include_router(gastos_router)
app.include_router(categorias_router)
app.include_router(dashboard_router)


@app.get("/", tags=["Frontend"])
def servir_frontend():
    return FileResponse("frontend/index.html")

@app.get("/status", tags=["Root"])
def root():
    return {
        "app": "MyPocketBudget API",
        "version": "1.0.0",
        "docs": "/docs",
        "padroes": ["Prototype", "Bridge", "Strategy"],
    }
