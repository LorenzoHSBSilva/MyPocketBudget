class Gasto:
    def __init__(self, valor, descricao, categoria, data):
        self.valor = valor
        self.descricao = descricao
        self.categoria = categoria
        self.data = data


class Categoria:
    def __init__(self, nome, limite):
        self.nome = nome
        self.limite = limite
        self.gastos = []

    def adicionar_gasto(self, gasto):
        self.gastos.append(gasto)

    def total_gastos(self):
        soma = 0
        for g in self.gastos:
            soma += g.valor
        return soma

    def verificar_limite(self):
        if self.total_gastos() > self.limite:
            print("Limite excedido:", self.nome)


class GerenciadorDeGastos:
    def __init__(self):
        self.gastos = []

    def adicionar_gasto(self, gasto):
        self.gastos.append(gasto)

    def listar_gastos(self):
        for g in self.gastos:
            print(g.descricao, "-", g.valor)

    def editar_gasto(self, indice, novo_valor, nova_descricao):
        self.gastos[indice].valor = novo_valor
        self.gastos[indice].descricao = nova_descricao
